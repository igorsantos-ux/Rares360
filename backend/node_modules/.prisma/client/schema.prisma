generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id                    String          @id @default(uuid())
  name                  String          // Nome de exibição principal
  razaoSocial           String?
  cnpj                  String?         @unique
  inscricaoEstadual     String?
  inscricaoMunicipal    String?
  cnae                  String?
  regimeTributario      String?         @default("SIMPLES")
  dataAbertura          DateTime?
  cep                   String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cidade                String?
  estado                String?
  telefone              String?
  whatsapp              String?
  email                 String?
  site                  String?
  codigoServico         String?
  aliquotaISS           Float?
  certificadoDigitalUrl String?
  banco                 String?
  agencia               String?
  conta                 String?
  tipoConta             String?
  chavePix              String?
  logo                  String?
  corMarca              String?
  responsavelAdmin      String?
  responsavelTecnico    String?
  crmResponsavel        String?
  registroVigilancia    String?
  cnes                  String?
  pricePerUser          Float           @default(50.0)
  isActive              Boolean         @default(true)
  users                 User[]
  transactions          Transaction[]
  doctors               Doctor[]
  customers             Customer[]
  stockItems            StockItem[]
  goals                 FinancialGoal[]
  documents             Document[]
  integrations          Integration[]
  insurances            Insurance[]
  specialties           Specialty[]
  procedures            Procedure[]
  financialCategories   FinancialCategory[]
  bankAccounts          BankAccount[]
  appointments          Appointment[]
  createdAt             DateTime        @default(now())
}

model Integration {
  id          String   @id @default(uuid())
  type        String   // "FEEGOW", etc.
  token       String
  settings    Json?    // Configurações adicionais em JSON
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, type])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   // "ADMIN_GLOBAL" or "CLINIC_ADMIN"
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Transaction {
  id            String   @id @default(uuid())
  description   String
  amount        Float
  netAmount     Float    @default(0) // Valor líquido (pós taxas)
  type          String   // "INCOME" or "EXPENSE"
  status        String   @default("PAID") // "PAID", "PENDING", "OVERDUE"
  paymentMethod String?  // "Cartão", "Pix", "Dinheiro", etc.
  category      String?  // Mantido para fallback
  
  categoryId    String?
  financialCategory FinancialCategory? @relation(fields: [categoryId], references: [id])
  
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  centerOfCost  String   @default("Operacional")
  procedureName String?
  cost          Float    @default(0)
  date          DateTime @default(now())
  
  externalId     String?
  externalSource String?

  doctorId      String?
  doctor        Doctor?  @relation(fields: [doctorId], references: [id])
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([externalId, externalSource, clinicId])
}

model Doctor {
  id                 String        @id @default(uuid())
  name               String
  specialty          String?       // Fallback
  rqe                String?
  documento_conselho String?
  uf_conselho        String?
  commission         Float
  transactions       Transaction[]
  specialties        Specialty[]
  appointments       Appointment[]
  
  clinicId           String
  clinic             Clinic        @relation(fields: [clinicId], references: [id])
}

model Customer {
  id             String        @id @default(uuid())
  name           String
  email          String?
  phone          String?
  birthDate      DateTime?
  lastVisit      DateTime?
  externalId     String?       // ID no sistema de origem (ex: Feegow)
  externalSource String?       // Qual plataforma de origem (ex: "FEEGOW")
  transactions   Transaction[]
  appointments   Appointment[]
  createdAt      DateTime      @default(now())
  
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])

  @@unique([externalId, externalSource, clinicId])
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  source    String
  status    String
  createdAt DateTime @default(now())
}

model StockItem {
  id           String   @id @default(uuid())
  name         String
  category     String
  quantity     Int
  minQuantity  Int
  price        Float
  lastRestock  DateTime @default(now())
  
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
}

model FinancialGoal {
  id        String   @id @default(uuid())
  month     Int
  year      Int
  target    Float
  achieved  Float    @default(0)
  type      String
  
  clinicId  String
  clinic    Clinic @relation(fields: [clinicId], references: [id])
}

model Document {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String   // "Contract", "PatientDoc", "Admin"
  category  String?
  createdAt DateTime @default(now())
  
  clinicId  String
  clinic    Clinic @relation(fields: [clinicId], references: [id])
}

model Insurance {
  id             String        @id @default(uuid())
  nome           String
  registroAns    String?
  cnpj           String?
  isActive       Boolean       @default(true)
  externalId     String?
  externalSource String?
  
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  plans          InsurancePlan[]
  appointments   Appointment[]

  @@unique([externalId, externalSource, clinicId])
}

model InsurancePlan {
  id             String        @id @default(uuid())
  nome           String
  externalId     String?
  externalSource String?
  
  insuranceId    String
  insurance      Insurance     @relation(fields: [insuranceId], references: [id])
  appointments   Appointment[]

  @@unique([externalId, externalSource, insuranceId])
}

model Specialty {
  id             String        @id @default(uuid())
  nome           String
  codigoTiss     String?
  externalId     String?
  externalSource String?
  
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  doctors        Doctor[]      
  appointments   Appointment[]
  procedures     Procedure[]

  @@unique([externalId, externalSource, clinicId])
}

model Procedure {
  id               String        @id @default(uuid())
  nome             String
  codigo           String?
  valorPadrao      Float         @default(0)
  tempoMinutos     Int?
  tipoProcedimento String?
  externalId       String?
  externalSource   String?
  
  clinicId         String
  clinic           Clinic        @relation(fields: [clinicId], references: [id])
  specialties      Specialty[]
  appointments     Appointment[]

  @@unique([externalId, externalSource, clinicId])
}

model FinancialCategory {
  id             String        @id @default(uuid())
  nome           String
  tipo           String        // "INCOME" or "EXPENSE"
  parentId       String?       
  externalId     String?
  externalSource String?
  
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  transactions   Transaction[]

  @@unique([externalId, externalSource, clinicId])
}

model BankAccount {
  id             String        @id @default(uuid())
  nome           String
  tipoConta      String?
  banco          String?
  externalId     String?
  externalSource String?
  
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  transactions   Transaction[]

  @@unique([externalId, externalSource, clinicId])
}

model Appointment {
  id                  String        @id @default(uuid())
  date                DateTime
  time                String?
  notes               String?
  agendadoPor         String?
  telemedicina        Boolean       @default(false)
  primeiroAgendamento Boolean       @default(false)
  status              String        @default("SCHEDULED")
  
  doctorId            String?
  doctor              Doctor?       @relation(fields: [doctorId], references: [id])
  
  customerId          String?
  customer            Customer?     @relation(fields: [customerId], references: [id])
  
  procedureId         String?
  procedure           Procedure?    @relation(fields: [procedureId], references: [id])
  
  insuranceId         String?
  insurance           Insurance?    @relation(fields: [insuranceId], references: [id])
  
  insurancePlanId     String?
  insurancePlan       InsurancePlan? @relation(fields: [insurancePlanId], references: [id])
  
  specialtyId         String?
  specialty           Specialty?    @relation(fields: [specialtyId], references: [id])

  clinicId            String
  clinic              Clinic        @relation(fields: [clinicId], references: [id])
  
  transactions        Transaction[]

  externalId          String?
  externalSource      String?

  @@unique([externalId, externalSource, clinicId])
}
