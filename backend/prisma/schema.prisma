generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id                    String               @id @default(uuid())
  name                  String
  razaoSocial           String?
  cnpj                  String?              @unique
  inscricaoEstadual     String?
  inscricaoMunicipal    String?
  cnae                  String?
  regimeTributario      String?              @default("SIMPLES")
  dataAbertura          DateTime?
  cep                   String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cidade                String?
  estado                String?
  telefone              String?
  whatsapp              String?
  email                 String?
  site                  String?
  codigoServico         String?
  aliquotaISS           Float?
  certificadoDigitalUrl String?
  banco                 String?
  agencia               String?
  conta                 String?
  tipoConta             String?
  chavePix              String?
  logo                  String?
  corMarca              String?
  responsavelAdmin      String?
  responsavelTecnico    String?
  crmResponsavel        String?
  registroVigilancia    String?
  cnes                  String?
  pricePerUser          Float                @default(50.0)
  implementationFee     Float?               @default(0)
  monthlyFee            Float?               @default(0)
  proposalUrl           String?
  isActive              Boolean              @default(true)
  plan                  String?              @default("Essencial")
  
  // Campos de Contrato
  contractStartDate       DateTime?
  contractDurationMonths  Int?                 @default(12)
  contractStatus          String?              @default("ATIVO") // ATIVO, RENOVACAO, ENCERRADO

  // Campos de Setup / Implementação
  setupValue              Float?               @default(0)
  setupPaymentType        String?              @default("DILUIDO_NA_MENSALIDADE") // DILUIDO_NA_MENSALIDADE, PARCELADO_SEPARADO
  setupInstallments       Int?                 @default(1)
  setupRemainingInstallments Int?              @default(0)

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @default(now()) @updatedAt
  lastUpdatedBy         String?
  accountPayables       AccountPayable[]
  clinicDocuments       ClinicDocument[]
  dailyClosures         DailyClosure[]
  doctors               Doctor[]
  documents             Document[]
  goals                 FinancialGoal[]
  inventoryItems        InventoryItem[]
  leads                 Lead[]
  patients              Patient[]
  pricingSimulations    PricingSimulation[]
  procedureExecutions   ProcedureExecution[]
  procedures            Procedure[]
  stockMovements        StockMovement[]
  tasks                 Task[]
  transactions          Transaction[]
  users                 User[]
  appointments          Appointment[]
  rooms                 Room[]
  equipments            Equipment[]
  evolutions            ClinicalEvolution[]
  prescriptions         Prescription[]
  inventoryUsages       InventoryUsage[]
  proposals             Proposal[]
  invoices              Invoice[]
  monthlyGoals          MonthlyGoal[]
  importBatches         ImportBatch[]
  treatmentPlans        TreatmentPlan[]
  accountReceivables    AccountReceivable[]

  // ═══ Módulo de Faturamento V2 ═══
  formasPagamento       FormaPagamento[]
  categoriasProcedimento CategoriaProcedimento[]
  orcamentos            Orcamento[]
  contratos             Contrato[]
  contasPaciente        ContaPaciente[]
  termos                Termo[]
  setores               Setor[]
  fornecedores          Fornecedor[]
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  EXPORT
  VIEW_SENSITIVE
  ADMIN_CLINIC_ACCESS
  ADMIN_CLINIC_EXIT
}

model AuditLog {
  id        String      @id @default(uuid())
  clinicId  String
  userId    String?
  action    AuditAction
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  timestamp DateTime    @default(now())

  // Note: Relação opcional com clinic e user para não forçar integridade referencial rígida no log, 
  // que deve ser imutável mesmo se um usuário for deletado.
  
  @@index([clinicId, entity, entityId])
  @@index([clinicId, action])
  @@index([clinicId, userId])
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  password          String
  name              String
  role              String            // Templates: OWNER, ADMIN, DOCTOR, RECEPTIONIST
  permissions       Json?             // Granular access: { patients: "WRITE", finance: "NONE", etc }
  clinicId          String?
  createdAt         DateTime          @default(now())
  isActive          Boolean           @default(true)
  hasSeenOnboarding Boolean           @default(false)
  
  // Novos campos de segurança
  passwordUpdatedAt DateTime          @default(now())
  mustChangePassword Boolean          @default(true)
  passwordHistory   PasswordHistory[]

  isFirstAccess     Boolean           @default(true)
  lastLoginAt       DateTime?
  createdByAdminId  String?
  temporaryPasswordExpiresAt DateTime?

  closedChapters    DailyClosure[]    @relation("ClosedBy")
  clinic            Clinic?           @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String
  hash      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id                 String              @id @default(uuid())
  description        String
  amount             Float
  netAmount          Float               @default(0)
  type               String
  status             String              @default("PAID")
  paymentMethod      String?
  category           String
  centerOfCost       String              @default("Operacional")
  procedureName      String?
  doctorName         String?
  cost               Float               @default(0)
  date               DateTime            @default(now())
  doctorId           String?
  clinicId           String
  dueDate            DateTime?
  fileUrl            String?
  patientId          String?
  quantity           Float               @default(1)
  isExecuted         Boolean             @default(false)
  procedureExecution ProcedureExecution?
  
  importBatchId      String?
  importBatch        ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  clinic             Clinic              @relation(fields: [clinicId], references: [id])
  doctor             Doctor?             @relation(fields: [doctorId], references: [id])
  patient            Patient?            @relation(fields: [patientId], references: [id])

  @@index([clinicId, date])
  @@index([clinicId, status])
  @@index([patientId])
  @@index([importBatchId])
}

model Doctor {
  id                String        @id @default(uuid())
  name              String
  cpf               String?       @unique
  birthDate         DateTime?
  email             String?
  crm               String?
  crmUf             String?
  rqe               String?
  specialty         String
  phone             String?
  isActive          Boolean       @default(true)
  commission        Float
  
  // Novos campos financeiros
  consultationValue Float?
  repasseType       String?
  repasseValue      Float?
  pixKey            String?
  
  // Disponibilidade
  defaultDuration   Int           @default(30)
  availability      Json?
  
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  transactions Transaction[]
  appointments Appointment[]
  evolutions   ClinicalEvolution[]
  executedProposals Proposal[] @relation("ExecutedProposals")
  executedTreatmentItems TreatmentItem[]

  @@index([clinicId])
}

model Patient {
  id                        String               @id @default(uuid())
  fullName                  String
  socialName                String?
  cpf                       String?              @unique
  rg                        String?
  birthDate                 DateTime?
  gender                    String?
  color                     String?
  maritalStatus             String?
  profession                String?
  education                 String?
  religion                  String?
  phone                     String?
  email                     String?
  address                   String?
  origin                    String?
  weight                    Float?
  height                    Float?
  disability                String?
  allergies                 String?
  historyOfAllergies        String?
  financialResponsibleName  String?
  financialResponsibleCpf   String?
  tags                      String[]             @default([])
  smoker                    Boolean              @default(false)
  priority                  String?
  insurance                 String?
  insurancePlan             String?
  healthInsurance           String?
  leadSource                String?
  photoUrl                  String?
  isActive                  Boolean              @default(true)
  cachedLtv                 Float                @default(0)
  lastVisit                 DateTime?
  createdAt                 DateTime             @default(now())
  clinicId                  String
  
  importBatchId             String?
  importBatch               ImportBatch?         @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  // LGPD & Soft Delete
  deletedAt                 DateTime?
  consentDataProcessing     Boolean              @default(false)
  consentMarketing          Boolean              @default(false)
  consentTermsVersion       String?
  consentDate               DateTime?
  anonymizedAt              DateTime?             // LGPD: Data da anonimização

  clinic                    Clinic               @relation(fields: [clinicId], references: [id])
  procedureExecutions       ProcedureExecution[]
  tasks                     Task[]
  transactions              Transaction[]
  appointments              Appointment[]
  evolutions                ClinicalEvolution[]
  prescriptions             Prescription[]
  inventoryUsages           InventoryUsage[]
  proposals                 Proposal[]
  treatmentPlans            TreatmentPlan[]
  accountReceivables        AccountReceivable[]

  // ═══ Módulo de Faturamento V2 ═══
  orcamentos                Orcamento[]
  contasPaciente            ContaPaciente[]
  documentosPaciente        DocumentoPaciente[]

  @@index([clinicId, fullName])
  @@index([importBatchId])
}

model ClinicalEvolution {
  id             String   @id @default(uuid())
  text           String
  date           DateTime @default(now())
  locked         Boolean  @default(false)
  professionalId String
  patientId      String
  clinicId       String
  
  clinic       Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Doctor  @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([clinicId, patientId])
}

model Prescription {
  id          String   @id @default(uuid())
  content     Json?
  medications Json
  printedAt   DateTime?
  createdAt   DateTime @default(now())
  patientId   String
  clinicId    String

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId, patientId])
}

model InventoryUsage {
  id              String   @id @default(uuid())
  quantity        Float
  inventoryItemId String
  appointmentId   String?
  patientId       String
  clinicId        String
  createdAt       DateTime @default(now())

  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id])

  @@index([clinicId, patientId])
}

enum ProposalStatus {
  PENDENTE
  CONTRATO
  APROVADO
  EXECUTADO
}

model Proposal {
  id           String         @id @default(uuid())
  items        Json
  totalValue   Float
  status       ProposalStatus @default(PENDENTE)
  contractUrl  String?
  executedAt   DateTime?
  executedById String?
  
  createdAt    DateTime       @default(now())
  patientId    String
  clinicId     String

  clinic       Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Doctor? @relation("ExecutedProposals", fields: [executedById], references: [id])

  @@index([clinicId, patientId])
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  source    String
  status    String
  createdAt DateTime @default(now())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

model InventoryItem {
  id              String           @id @default(uuid())
  code            String?          // Mapeado de "CÓD"
  isActive        Boolean          @default(true) // Mapeado de "STATUS"
  name            String           // Mapeado de "NOME DO PRODUTO"
  category        String           // Mapeado de "CATEGORIA"
  unit            String           @default("Unidade") // Mapeado de "UNIDADE"
  manufacturer    String?          // Mapeado de "FABRICANTE"
  currentStock    Float            @default(0) // Mapeado de "QTD ESTOQUE ATUAL"
  minQuantity     Float            @default(0) // Mapeado de "QTD MÍNIMA"
  unitCost        Float            @default(0) // Mapeado de "VALOR UNITÁRIO"
  supplier        String?
  expirationDate  DateTime?
  batch           String?
  lastRestock     DateTime         @default(now())
  clinicId        String
  
  // PGE - Inteligência de Compras
  leadTime        Int              @default(7)   // Dias para fornecedor entregar
  desiredCoverage Int              @default(30)  // Dias de cobertura desejada
  safetyStock     Float            @default(0)   // Estoque de segurança
  setorId         String?
  quantidadeIdeal Float?
  giroMensal      Float?
  ultimoCustoData DateTime?
  fornecedorPadraoId String?
  
  importBatchId   String?
  importBatch     ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  clinic          Clinic           @relation(fields: [clinicId], references: [id])
  setor           Setor?           @relation(fields: [setorId], references: [id])
  fornecedorPadrao Fornecedor?     @relation(fields: [fornecedorPadraoId], references: [id])
  movements       StockMovement[]
  inventoryUsages InventoryUsage[]
  procedimentoInsumos ProcedimentoInsumo[]

  @@index([clinicId, name])
  @@index([importBatchId])
}

model Fornecedor {
  id              String          @id @default(uuid())
  clinicId        String
  nome            String
  cnpj            String?
  email           String?
  telefone        String?
  whatsapp        String?
  ativo           Boolean         @default(true)
  itensEstoque    InventoryItem[]
  clinic          Clinic          @relation(fields: [clinicId], references: [id])
  createdAt       DateTime        @default(now())

  @@index([clinicId])
}

model Setor {
  id          String   @id @default(cuid())
  clinicId    String
  nome        String   // Enfermagem | Escritório | Copa | Limpeza | Estética
  slug        String   // enfermagem | escritorio | copa | limpeza | estetica
  cor         String   // hex para badge visual
  icone       String   // nome do ícone Lucide React
  ordem       Int      @default(0)
  ativo       Boolean  @default(true)
  itensEstoque InventoryItem[]
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())

  @@index([clinicId])
}

model StockMovement {
  id            String        @id @default(uuid())
  type          MovementType
  quantity      Float
  reason        String?
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())
  userId        String?
  itemId        String
  clinicId      String
  importBatchId String?

  importBatch   ImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([clinicId, itemId])
  @@index([importBatchId])
}

model FinancialGoal {
  id       String @id @default(uuid())
  month    Int
  year     Int
  target   Float
  achieved Float  @default(0)
  type     String
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  @@index([clinicId, month, year])
}

model Document {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String
  category  String?
  createdAt DateTime @default(now())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

model ClinicDocument {
  id         String    @id @default(uuid())
  clinicId   String
  title      String
  category   String
  status     String    @default("PENDENTE")
  fileUrl    String?
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  clinic     Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model AccountPayable {
  id                  String                      @id @default(uuid())
  description         String
  documentNumber      String?
  totalAmount         Float
  paymentMethod       String?
  isInstallment       Boolean                     @default(false)
  installmentsCount   Int                         @default(1)
  installmentInterval String?
  dueDate             DateTime?                   // Campo para importação simplificada/flat
  paymentDate         DateTime?                   // Campo para importação simplificada/flat
  expenseType         String?                     // Mapeado de "TIPO DE DESPESA"
  category            String?                     // Mapeado de "CLASSIFICAÇÃO"
  payee               String?                     // Mapeado de "FAVORECIDO/BENEFICIÁRIO"
  notes               String?                     // Mapeado de "OBSERVAÇÃO NF - BOLETO"
  
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  clinicId            String
  interestValue       Float                       @default(0)
  penaltyValue        Float                       @default(0)
  supplierCnpj        String?
  supplierName        String?
  bank                String?
  fileUrl             String?
  observation         String?
  costCenter          String?
  costType            String?
  status              String                      @default("PENDENTE")
  
  importBatchId       String?
  importBatch         ImportBatch?                @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  clinic              Clinic                      @relation(fields: [clinicId], references: [id])
  installments        AccountPayableInstallment[]

  @@index([clinicId, status])
  @@index([importBatchId])
}

model AccountPayableInstallment {
  id                String         @id @default(uuid())
  accountPayableId  String
  installmentNumber Int
  amount            Float
  dueDate           DateTime
  status            String         @default("PENDENTE")
  paidAt            DateTime?
  paymentMethod     String?
  accountPayable    AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)

  @@index([accountPayableId, status])
  @@index([dueDate])
}

model PricingSimulation {
  id                String          @id @default(uuid())
  name              String
  sellingPrice      Float
  totalCost         Float
  netProfit         Float
  profitMargin      Float
  cardFeePercentage Float           @default(0)
  taxPercentage     Float           @default(0)
  fixedCost         Float           @default(0)
  commission        Float           @default(0)
  clinicId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  clinic            Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  supplies          PricingSupply[]
}

model PricingSupply {
  id                  String             @id @default(uuid())
  name                String
  quantity            Float
  cost                Float
  pricingSimulationId String?
  procedureId         String?
  pricingSimulation   PricingSimulation? @relation(fields: [pricingSimulationId], references: [id], onDelete: Cascade)
  procedure           Procedure?         @relation(fields: [procedureId], references: [id], onDelete: Cascade)
}

model Procedure {
  id              String          @id @default(cuid())
  name            String
  category        String          @default("Geral")
  durationMinutes Int             @default(0)
  
  // Detalhes Financeiros
  fixedCost       Float           @default(0)
  variableCost    Float           @default(0)
  taxes           Float           @default(0)
  commission      Float           @default(0)
  basePrice       Float           @default(0)
  
  // Campos Legados / Agregações
  totalCost       Float           @default(0) // (fixedCost + variableCost + impostos + comissao)
  currentPrice    Float           @default(0) // Preço praticado hoje
  targetMargin    Float           @default(50)
  
  // Novos Campos Operacionais e CRM
  productName     String?
  taskCount       Int             @default(0)
  followUpDays    Int?            // Gatilho para CRM (ex: 120 dias)

  clinicId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // ═══ Faturamento V2: Categoria tipada ═══
  categoriaId     String?

  importBatchId String?
  importBatch   ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  supplies      PricingSupply[]
  appointments  Appointment[]
  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  treatmentItems TreatmentItem[]
  categoriaProc CategoriaProcedimento? @relation(fields: [categoriaId], references: [id])
  procedimentoInsumos ProcedimentoInsumo[]
  orcamentoItens      OrcamentoItem[]
  contaPacienteItens  ContaPacienteItem[]
  termos              Termo[]

  @@index([clinicId])
  @@index([importBatchId])
}

model DailyClosure {
  id             String        @id @default(uuid())
  date           DateTime
  openingBalance Float         @default(0)
  totalIncomes   Float         @default(0)
  totalExpenses  Float         @default(0)
  closingBalance Float         @default(0)
  closedAt       DateTime      @default(now())
  closedById     String
  clinicId       String
  status         ClosureStatus @default(CLOSED)
  notes          String?
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  closedBy       User          @relation("ClosedBy", fields: [closedById], references: [id])

  @@unique([clinicId, date])
}

model ProcedureExecution {
  id            String       @id @default(uuid())
  clinicId      String
  patientId     String
  procedureId   String?
  procedureName String
  transactionId String?      @unique
  status        String       @default("PENDENTE")
  billedAt      DateTime     @default(now())
  executedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  tasks         Task[]

  @@index([clinicId, status])
}

model Task {
  id          String              @id @default(uuid())
  clinicId    String
  patientId   String
  executionId String?
  assignedTo  String?             // ID do usuário comercial
  title       String
  description String?
  dueDate     DateTime
  status      String              @default("TODO") // TODO, IN_PROGRESS, DONE, LOST
  type        String              @default("FOLLOW_UP")
  priority    String              @default("MEDIUM") // LOW, MEDIUM, HIGH
  pendingProcedures Json?               // Lista de procedimentos consolidados
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  clinic      Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  execution   ProcedureExecution? @relation(fields: [executionId], references: [id])
  patient     Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId, dueDate])
  @@index([clinicId, status])
}

enum MovementType {
  IN
  OUT
}

enum ClosureStatus {
  OPEN
  CLOSED
}

model GlobalLead {
  id              String           @id @default(uuid())
  name            String
  email           String
  whatsapp        String
  subject         String           @default("Demonstração")
  message         String           @default("")
  diagnostic      Json?

  // ═══ Campos tipados do formulário de captação (v2) ═══
  clinica         String?          // Nome da clínica
  especialidade   String?          // Especialidade da clínica
  volumeMensal    String?          // Volume aproximado de atendimentos/mês
  desafio         String?          // Principal desafio
  origem          String?          // Como nos conheceu
  source          String           @default("website") // website | manual | api
  ipOrigem        String?          // IP de origem para auditoria
  consentimento   Boolean          @default(false)      // Aceite de contato

  // ═══ Gestão do pipeline ═══
  assignedTo      String?          // userId do admin responsável
  contatadoEm     DateTime?        // Data do primeiro contato
  fechadoEm       DateTime?        // Data do fechamento

  status          GlobalLeadStatus @default(NOVO)
  score           Int              @default(0)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum GlobalLeadStatus {
  NOVO
  EM_CONTATO
  DIAGNOSTICO
  DEMONSTRACAO
  FECHADO
  PERDIDO
}

model Room {
  id           String        @id @default(uuid())
  name         String
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([clinicId])
}

model Equipment {
  id           String        @id @default(uuid())
  name         String
  status       String?       @default("ATIVO")
  clinicId     String
  
  importBatchId String?
  importBatch   ImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([clinicId])
  @@index([importBatchId])
}

model Appointment {
  id             String            @id @default(uuid())
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(AGUARDANDO)
  isOverbook     Boolean           @default(false)
  isReturn       Boolean           @default(false)
  notes          String?
  
  patientId      String
  professionalId String
  roomId         String?
  equipmentId    String?
  clinicId       String
  procedureId    String?           // Vinculado ao ProcedurePricing para obter tempo e insumos

  clinic          Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional    Doctor            @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  room            Room?             @relation(fields: [roomId], references: [id])
  equipment       Equipment?        @relation(fields: [equipmentId], references: [id])
  procedure       Procedure?        @relation(fields: [procedureId], references: [id])
  inventoryUsages InventoryUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, startTime])
  @@index([clinicId, status])
}

enum AppointmentStatus {
  AGUARDANDO
  AGUARDANDO_PAGAMENTO
  ATENDIDO
  CANCELADO_PROFISSIONAL
  CHAMANDO
  DESMARCADO_PACIENTE
  EM_ATENDIMENTO
  CONFIRMADO
  NAO_CONFIRMADO
  FALTA
  REMARCADO
  CHECK_IN
  EXECUTADO
  CANCELADO
}

model Invoice {
  id                String   @id @default(uuid())
  clinicId          String
  month             Int
  year              Int
  description       String
  saasAmount        Float    @default(0)
  setupAmount       Float    @default(0)
  totalAmount       Float    @default(0)
  status            String   @default("PENDENTE") // PENDENTE, PAGO, CANCELADO
  type              String   @default("MENSALIDADE") // MENSALIDADE, SETUP, MENSALIDADE_E_SETUP
  installmentNumber Int?
  createdAt         DateTime @default(now())
  dueDate           DateTime

  clinic            Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status])
  @@index([clinicId, month, year])
}

enum GoalType {
  COMERCIAL
  ESTOQUE
  OPERACIONAL
}

model MonthlyGoal {
  id            String   @id @default(cuid())
  clinicId      String
  monthYear     String   // ex: "04-2026"
  name          String?  @default("Meta de Faturamento")
  type          GoalType @default(COMERCIAL)
  isPrimary     Boolean  @default(false)
  targetValue   Float    @default(0)
  workingDays   Int      @default(22)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([clinicId, monthYear])
}


enum ImportModule {
  PACIENTES
  FATURAMENTO
  ESTOQUE
  PROCEDIMENTOS
  CONTAS_A_PAGAR
  MOVIMENTACAO
}

model ImportBatch {
  id          String       @id @default(cuid())
  clinicId    String
  module      ImportModule
  fileName    String
  recordCount Int
  createdAt   DateTime     @default(now())
  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Relações reversas para visualização facilitada (opcional, mas bom para integridade)
  patients           Patient[]
  transactions       Transaction[]
  inventoryItems     InventoryItem[]
  procedures         Procedure[]
  equipments         Equipment[]
  accountPayables    AccountPayable[]
  stockMovements     StockMovement[]
  errors             ImportErrorLog[]

  @@index([clinicId])
}

model ImportErrorLog {
  id            String      @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  rowNumber     Int
  rowData       Json
  errorMessage  String
  createdAt     DateTime    @default(now())

  @@index([importBatchId])
}

model AdminAuditLog {
  id                String   @id @default(uuid())
  adminId           String
  adminName         String
  targetClinicId    String
  targetClinicName  String?
  action            String   @default("CONTEXT_SWITCH")
  timestamp         DateTime @default(now())

  @@index([adminId])
  @@index([targetClinicId])
}

enum TreatmentPlanStatus {
  DRAFT
  APPROVED
  CANCELLED
  COMPLETED
}

enum TreatmentItemStatus {
  PENDING
  EXECUTED
}

model TreatmentPlan {
  id           String              @id @default(uuid())
  patientId    String
  clinicId     String
  totalAmount  Float
  status       TreatmentPlanStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic       Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  items        TreatmentItem[]
  receivables  AccountReceivable[]

  @@index([clinicId, patientId])
}

model TreatmentItem {
  id               String              @id @default(uuid())
  treatmentPlanId  String
  procedureId      String
  procedureName    String              // Denormalizado para histórico persistente
  unitValue        Float
  discount         Float               @default(0)
  finalValue       Float
  status           TreatmentItemStatus @default(PENDING)
  executedAt       DateTime?
  executedById     String?
  
  treatmentPlan    TreatmentPlan       @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  procedure        Procedure           @relation(fields: [procedureId], references: [id])
  executedBy       Doctor?             @relation(fields: [executedById], references: [id])

  @@index([treatmentPlanId])
}

model AccountReceivable {
  id              String        @id @default(uuid())
  treatmentPlanId String
  clinicId        String
  patientId       String
  description     String
  amount          Float
  dueDate         DateTime
  status          String        @default("PENDENTE") // PENDENTE, RECEBIDO, CANCELADO
  paymentMethod   String?
  installmentNumber Int?
  
  treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  clinic          Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId, treatmentPlanId])
  @@index([patientId])
}
// ═══════════════════════════════════════════════════════
// MÓDULO DE FATURAMENTO V2 — Fluxo Comercial Integrado
// Orçamento → Contrato → Conta → Execução → Baixa
// ═══════════════════════════════════════════════════════

model FormaPagamento {
  id                  String    @id @default(cuid())
  clinicId            String
  nome                String
  tipo                String    // DINHEIRO|PIX|CREDITO|DEBITO|BOLETO
  taxaPercentual      Decimal   @default(0)
  taxaFixa            Decimal   @default(0)
  taxaAntecipacao     Decimal   @default(0)
  prazoRecebimento    Int       @default(0)
  permiteParcelamento Boolean   @default(false)
  parcelasMaximas     Int       @default(1)
  taxaPorParcela      Json?     // {"2":1.99,"3":2.49,...}
  ativo               Boolean   @default(true)
  ordem               Int       @default(0)
  clinic              Clinic    @relation(fields: [clinicId], references: [id])
  orcamentos          Orcamento[]
  contasPaciente      ContaPaciente[]
  createdAt           DateTime  @default(now())

  @@index([clinicId])
}

model CategoriaProcedimento {
  id            String      @id @default(cuid())
  clinicId      String
  nome          String
  cor           String?
  ativa         Boolean     @default(true)
  procedimentos Procedure[]
  clinic        Clinic      @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

model ProcedimentoInsumo {
  id               String        @id @default(cuid())
  procedimentoId   String
  itemEstoqueId    String
  quantidadePadrao Decimal
  obrigatorio      Boolean       @default(true)
  procedimento     Procedure     @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)
  itemEstoque      InventoryItem @relation(fields: [itemEstoqueId], references: [id])

  @@index([procedimentoId])
}

model Orcamento {
  id               String         @id @default(cuid())
  clinicId         String
  numero           String         // ORC-2026-00001
  pacienteId       String
  formaPagamentoId String
  parcelas         Int            @default(1)
  valorBruto       Decimal
  valorDesconto    Decimal        @default(0)
  tipoDesconto     String         @default("VALOR") // VALOR|PERCENTUAL
  valorLiquido     Decimal
  taxasTotal       Decimal        @default(0)
  valorFinal       Decimal
  observacoes      String?
  status           String         @default("RASCUNHO") // RASCUNHO|ENVIADO|APROVADO|REJEITADO|EXPIRADO|CONVERTIDO
  validadeDias     Int            @default(15)
  validoAte        DateTime
  aprovadoEm       DateTime?
  aprovadoPor      String?
  contratoId       String?        @unique
  contaPacienteId  String?        @unique
  itens            OrcamentoItem[]
  formaPagamento   FormaPagamento @relation(fields: [formaPagamentoId], references: [id])
  paciente         Patient        @relation(fields: [pacienteId], references: [id])
  clinic           Clinic         @relation(fields: [clinicId], references: [id])
  contrato         Contrato?
  contaPaciente    ContaPaciente?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([clinicId, status])
  @@index([clinicId, pacienteId])
}

model OrcamentoItem {
  id              String    @id @default(cuid())
  orcamentoId     String
  procedimentoId  String
  quantidade      Int       @default(1)
  valorUnitario   Decimal
  desconto        Decimal   @default(0)
  valorTotal      Decimal
  orcamento       Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  procedimento    Procedure @relation(fields: [procedimentoId], references: [id])

  @@index([orcamentoId])
}

model Contrato {
  id            String    @id @default(cuid())
  clinicId      String
  orcamentoId   String    @unique
  numero        String    // CONTR-2026-00001
  pdfUrl        String
  pdfHash       String
  conteudoHTML  String
  geradoEm      DateTime  @default(now())
  geradoPor     String
  assinadoEm    DateTime?
  assinaturaUrl String?
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id])
  clinic        Clinic    @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

model ContaPaciente {
  id               String                  @id @default(cuid())
  clinicId         String
  pacienteId       String
  orcamentoId      String?                 @unique
  numero           String                  // CT-2026-00001
  valorTotal       Decimal
  valorPago        Decimal                 @default(0)
  saldoDevedor     Decimal
  formaPagamentoId String
  parcelas         Int                     @default(1)
  parcelasGeradas  Boolean                 @default(false)
  status           String                  @default("ABERTA") // ABERTA|PAGA|CANCELADA
  observacoes      String?
  itens            ContaPacienteItem[]
  parcelasFinanc   ParcelaContaPaciente[]
  documentos       DocumentoPaciente[]
  paciente         Patient                 @relation(fields: [pacienteId], references: [id])
  formaPagamento   FormaPagamento          @relation(fields: [formaPagamentoId], references: [id])
  orcamento        Orcamento?              @relation(fields: [orcamentoId], references: [id])
  clinic           Clinic                  @relation(fields: [clinicId], references: [id])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([clinicId, status])
  @@index([clinicId, pacienteId])
}

model ContaPacienteItem {
  id                  String                  @id @default(cuid())
  contaId             String
  procedimentoId      String
  quantidade          Int
  quantidadeExecutada Int                     @default(0)
  valorUnitario       Decimal
  valorTotal          Decimal
  status              String                  @default("PENDENTE") // PENDENTE|EXECUTADO_PARCIAL|EXECUTADO
  execucoes           ExecucaoProcedimentoV2[]
  conta               ContaPaciente           @relation(fields: [contaId], references: [id], onDelete: Cascade)
  procedimento        Procedure               @relation(fields: [procedimentoId], references: [id])

  @@index([contaId])
}

model ParcelaContaPaciente {
  id             String        @id @default(cuid())
  contaId        String
  numeroParcela  Int
  valorParcela   Decimal
  valorTaxa      Decimal       @default(0)
  valorLiquido   Decimal
  vencimento     DateTime
  pago           Boolean       @default(false)
  pagoEm         DateTime?
  conta          ContaPaciente @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId])
  @@index([vencimento])
}

// Renomeado para V2 para não conflitar com ProcedureExecution legado
model ExecucaoProcedimentoV2 {
  id              String                 @id @default(cuid())
  contaItemId     String
  pacienteId      String
  procedimentoId  String
  profissionalId  String
  dataExecucao    DateTime
  observacoes     String?
  baixasEstoque   BaixaEstoqueExecucao[]
  contaItem       ContaPacienteItem      @relation(fields: [contaItemId], references: [id])
  registradoPor   String
  createdAt       DateTime               @default(now())

  @@index([contaItemId])
  @@index([pacienteId])
}

model BaixaEstoqueExecucao {
  id             String                 @id @default(cuid())
  execucaoId     String
  itemEstoqueId  String
  quantidade     Decimal
  custoUnitario  Decimal                @default(0)
  custoTotal     Decimal                @default(0)
  execucao       ExecucaoProcedimentoV2 @relation(fields: [execucaoId], references: [id], onDelete: Cascade)

  @@index([execucaoId])
  @@index([itemEstoqueId])
}

model Termo {
  id               String     @id @default(cuid())
  clinicId         String
  procedimentoId   String?
  tipo             String     // CONSENTIMENTO|CONTRATO_PADRAO|TERMO_PROCEDIMENTO|OUTRO
  nome             String
  descricao        String?
  arquivoUrl       String
  arquivoHash      String
  arquivoTamanho   Int
  arquivoMimeType  String
  ativo            Boolean    @default(true)
  versao           Int        @default(1)
  procedimento     Procedure? @relation(fields: [procedimentoId], references: [id])
  clinic           Clinic     @relation(fields: [clinicId], references: [id])
  uploadPor        String
  createdAt        DateTime   @default(now())

  @@index([clinicId])
  @@index([clinicId, tipo])
}

model DocumentoPaciente {
  id              String         @id @default(cuid())
  pacienteId      String
  contaId         String?
  termoId         String?
  tipo            String         // TERMO_ASSINADO|CONTRATO_ASSINADO|RG|CPF|EXAME|OUTRO
  nome            String
  arquivoUrl      String
  arquivoHash     String
  arquivoTamanho  Int
  assinadoEm      DateTime?
  paciente        Patient        @relation(fields: [pacienteId], references: [id])
  conta           ContaPaciente? @relation(fields: [contaId], references: [id])
  uploadPor       String
  uploadEm        DateTime       @default(now())

  @@index([pacienteId])
  @@index([contaId])
}

// ═══════════════════════════════════════════
// LGPD — Modelos de Conformidade
// ═══════════════════════════════════════════

// Registro de consentimento (Art. 8 LGPD)
model ConsentLog {
  id            String   @id @default(uuid())
  userId        String
  termsVersion  String   // ex: "v2.1"
  consentType   String   @default("DATA_PROCESSING") // DATA_PROCESSING, MARKETING, SHARING
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime @default(now())

  @@index([userId])
  @@index([userId, termsVersion])
}

// Registro de incidentes de segurança (Art. 48 LGPD)
model IncidentReport {
  id                  String   @id @default(uuid())
  reportedBy          String
  title               String
  description         String
  severity            String   // LOW, MEDIUM, HIGH, CRITICAL
  status              String   @default("OPEN") // OPEN, INVESTIGATING, CONTAINED, RESOLVED, CLOSED
  affectedDataTypes   String[] @default([])
  affectedUsersCount  Int      @default(0)
  containmentActions  String?
  anpdNotifiedAt      DateTime?
  resolvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([severity])
}

// Registro de Atividades de Tratamento — ROPA (Art. 37 LGPD)
model DataProcessingRegistry {
  id               String   @id @default(uuid())
  dataCategory     String   // ex: "Dados de Pacientes", "Dados Financeiros"
  purpose          String   // Finalidade do tratamento
  legalBasis       String   // Base legal (ex: "Consentimento", "Obrigação Legal")
  dataTypes        String[] @default([]) // Tipos de dados tratados
  retention        String   // Período de retenção
  thirdParties     String[] @default([]) // Terceiros com acesso
  securityMeasures String?  // Medidas de segurança aplicadas
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Política de retenção de dados
model DataRetentionPolicy {
  id              String   @id @default(uuid())
  dataType        String   @unique // ex: "access_logs", "financial_data", "patient_data"
  retentionMonths Int      // Período em meses
  legalBasis      String   // Lei/regulamento que exige a retenção
  autoDelete      Boolean  @default(false) // Se deve ser deletado automaticamente
  lastPurgeAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
