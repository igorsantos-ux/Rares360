generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id                    String               @id @default(uuid())
  name                  String
  razaoSocial           String?
  cnpj                  String?              @unique
  inscricaoEstadual     String?
  inscricaoMunicipal    String?
  cnae                  String?
  regimeTributario      String?              @default("SIMPLES")
  dataAbertura          DateTime?
  cep                   String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cidade                String?
  estado                String?
  telefone              String?
  whatsapp              String?
  email                 String?
  site                  String?
  codigoServico         String?
  aliquotaISS           Float?
  certificadoDigitalUrl String?
  banco                 String?
  agencia               String?
  conta                 String?
  tipoConta             String?
  chavePix              String?
  logo                  String?
  corMarca              String?
  responsavelAdmin      String?
  responsavelTecnico    String?
  crmResponsavel        String?
  registroVigilancia    String?
  cnes                  String?
  pricePerUser          Float                @default(50.0)
  implementationFee     Float?               @default(0)
  monthlyFee            Float?               @default(0)
  proposalUrl           String?
  isActive              Boolean              @default(true)
  createdAt             DateTime             @default(now())
  accountPayables       AccountPayable[]
  clinicDocuments       ClinicDocument[]
  dailyClosures         DailyClosure[]
  doctors               Doctor[]
  documents             Document[]
  goals                 FinancialGoal[]
  inventoryItems        InventoryItem[]
  leads                 Lead[]
  patients              Patient[]
  pricingSimulations    PricingSimulation[]
  procedureExecutions   ProcedureExecution[]
  procedurePricings     ProcedurePricing[]
  stockMovements        StockMovement[]
  tasks                 Task[]
  transactions          Transaction[]
  users                 User[]
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String
  name              String
  role              String
  clinicId          String?
  createdAt         DateTime       @default(now())
  isActive          Boolean        @default(true)
  hasSeenOnboarding Boolean        @default(false)
  closedChapters    DailyClosure[] @relation("ClosedBy")
  clinic            Clinic?        @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

model Transaction {
  id                 String              @id @default(uuid())
  description        String
  amount             Float
  netAmount          Float               @default(0)
  type               String
  status             String              @default("PAID")
  paymentMethod      String?
  category           String
  centerOfCost       String              @default("Operacional")
  procedureName      String?
  cost               Float               @default(0)
  date               DateTime            @default(now())
  doctorId           String?
  clinicId           String
  dueDate            DateTime?
  fileUrl            String?
  patientId          String?
  quantity           Float               @default(1)
  isExecuted         Boolean             @default(false)
  procedureExecution ProcedureExecution?
  clinic             Clinic              @relation(fields: [clinicId], references: [id])
  doctor             Doctor?             @relation(fields: [doctorId], references: [id])
  patient            Patient?            @relation(fields: [patientId], references: [id])

  @@index([clinicId, date])
  @@index([clinicId, status])
}

model Doctor {
  id           String        @id @default(uuid())
  name         String
  specialty    String
  commission   Float
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  transactions Transaction[]

  @@index([clinicId])
}

model Patient {
  id                  String               @id @default(uuid())
  fullName            String
  socialName          String?
  cpf                 String?              @unique
  rg                  String?
  birthDate           DateTime?
  gender              String?
  color               String?
  maritalStatus       String?
  profession          String?
  education           String?
  religion            String?
  phone               String?
  email               String?
  address             String?
  origin              String?
  weight              Float?
  height              Float?
  disability          String?
  allergies           String?
  smoker              Boolean              @default(false)
  priority            String?
  insurance           String?
  insurancePlan       String?
  photoUrl            String?
  createdAt           DateTime             @default(now())
  clinicId            String
  clinic              Clinic               @relation(fields: [clinicId], references: [id])
  procedureExecutions ProcedureExecution[]
  tasks               Task[]
  transactions        Transaction[]

  @@index([clinicId, fullName])
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  source    String
  status    String
  createdAt DateTime @default(now())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

model InventoryItem {
  id             String          @id @default(uuid())
  name           String
  category       String
  unit           String          @default("Unidade")
  quantity       Float           @default(0)
  minQuantity    Float           @default(0)
  unitCost       Float           @default(0)
  supplier       String?
  expirationDate DateTime?
  batch          String?
  lastRestock    DateTime        @default(now())
  clinicId       String
  clinic         Clinic          @relation(fields: [clinicId], references: [id])
  movements      StockMovement[]

  @@index([clinicId, name])
}

model StockMovement {
  id        String        @id @default(uuid())
  type      MovementType
  quantity  Float
  reason    String?
  createdAt DateTime      @default(now())
  userId    String?
  itemId    String
  clinicId  String
  clinic    Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([clinicId, itemId])
}

model FinancialGoal {
  id       String @id @default(uuid())
  month    Int
  year     Int
  target   Float
  achieved Float  @default(0)
  type     String
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])
}

model Document {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String
  category  String?
  createdAt DateTime @default(now())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
}

model ClinicDocument {
  id         String    @id @default(uuid())
  clinicId   String
  title      String
  category   String
  status     String    @default("PENDENTE")
  fileUrl    String?
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  clinic     Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model AccountPayable {
  id                  String                      @id @default(uuid())
  description         String
  documentNumber      String?
  totalAmount         Float
  paymentMethod       String?
  isInstallment       Boolean                     @default(false)
  installmentsCount   Int                         @default(1)
  installmentInterval String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  clinicId            String
  interestValue       Float                       @default(0)
  penaltyValue        Float                       @default(0)
  supplierCnpj        String?
  supplierName        String?
  bank                String?
  fileUrl             String?
  observation         String?
  costCenter          String?
  costType            String?
  status              String                      @default("PENDENTE")
  clinic              Clinic                      @relation(fields: [clinicId], references: [id])
  installments        AccountPayableInstallment[]

  @@index([clinicId, status])
}

model AccountPayableInstallment {
  id                String         @id @default(uuid())
  accountPayableId  String
  installmentNumber Int
  amount            Float
  dueDate           DateTime
  status            String         @default("PENDENTE")
  paidAt            DateTime?
  paymentMethod     String?
  accountPayable    AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
}

model PricingSimulation {
  id                String          @id @default(uuid())
  name              String
  sellingPrice      Float
  totalCost         Float
  netProfit         Float
  profitMargin      Float
  cardFeePercentage Float           @default(0)
  taxPercentage     Float           @default(0)
  fixedCost         Float           @default(0)
  commission        Float           @default(0)
  clinicId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  clinic            Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  supplies          PricingSupply[]
}

model PricingSupply {
  id                  String             @id @default(uuid())
  name                String
  quantity            Float
  cost                Float
  pricingSimulationId String?
  procedurePricingId  String?
  pricingSimulation   PricingSimulation? @relation(fields: [pricingSimulationId], references: [id], onDelete: Cascade)
  procedurePricing    ProcedurePricing?  @relation(fields: [procedurePricingId], references: [id], onDelete: Cascade)
}

model ProcedurePricing {
  id              String          @id @default(uuid())
  name            String
  durationMinutes Int             @default(0)
  totalCost       Float
  currentPrice    Float
  targetMargin    Float           @default(50)
  clinicId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  supplies        PricingSupply[]
  clinic          Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model DailyClosure {
  id             String        @id @default(uuid())
  date           DateTime
  openingBalance Float         @default(0)
  totalIncomes   Float         @default(0)
  totalExpenses  Float         @default(0)
  closingBalance Float         @default(0)
  closedAt       DateTime      @default(now())
  closedById     String
  clinicId       String
  status         ClosureStatus @default(CLOSED)
  notes          String?
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  closedBy       User          @relation("ClosedBy", fields: [closedById], references: [id])

  @@unique([clinicId, date])
}

model ProcedureExecution {
  id            String       @id @default(uuid())
  clinicId      String
  patientId     String
  procedureId   String?
  procedureName String
  transactionId String?      @unique
  status        String       @default("PENDENTE")
  billedAt      DateTime     @default(now())
  executedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  tasks         Task[]

  @@index([clinicId, status])
}

model Task {
  id          String              @id @default(uuid())
  clinicId    String
  patientId   String
  executionId String?
  title       String
  dueDate     DateTime
  status      String              @default("ABERTA")
  type        String              @default("FOLLOW_UP")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  clinic      Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  execution   ProcedureExecution? @relation(fields: [executionId], references: [id])
  patient     Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId, dueDate])
}

enum MovementType {
  ENTRADA
  SAIDA
}

enum ClosureStatus {
  OPEN
  CLOSED
}

model GlobalLead {
  id        String           @id @default(uuid())
  name      String
  email     String
  whatsapp  String
  subject   String
  message   String
  status    GlobalLeadStatus @default(NOVO)
  score     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum GlobalLeadStatus {
  NOVO
  EM_CONTATO
  CONVERTIDO
  ARQUIVADO
}
